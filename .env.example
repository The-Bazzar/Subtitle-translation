# ── 工具路径 (留空则用系统默认, Windows/Linux 分开) ──
MPV_PATH_WIN=
MPV_PATH_LINUX=
FFMPEG_PATH_WIN=
FFMPEG_PATH_LINUX=
YTDLP_PATH_WIN=
YTDLP_PATH_LINUX=

# ── WhisperX 语音识别 ──
# ASR 模型 (large-v3-turbo / large-v3 / small)
WHISPER_MODEL=large-v3-turbo
# 对齐模型 (Facebook MMS 或按语言自动)
WHISPER_ALIGN_MODEL=facebook/mms-1b-fl102
# 分割粒度: sentence (句子级, 短) / chunk (原始长段, 默认)
WHISPER_SEGMENT_RESOLUTION=sentence
# 每行最大字符数 (字幕标准: 42)
WHISPER_MAX_LINE_WIDTH=42
# 每段最大行数 (字幕标准: 2)
WHISPER_MAX_LINE_COUNT=2
# 处理块大小秒 (默认 15, WhisperX 原始: 30, 越小段越短)
WHISPER_CHUNK_SIZE=15
# VAD 语音活动检测阈值 (通常不需要改)
WHISPER_VAD_ONSET=0.5
WHISPER_VAD_OFFSET=0.363
# 是否用前文做 prompt (false=独立段更短, true=连成一段)
WHISPER_CONDITION_ON_PREVIOUS=false

# ── 翻译默认配置 ──
# openrouter | deepseek | gemini
TRANSLATE_PROVIDER=deepseek
# 模型名, 留空则使用后端内置默认
TRANSLATE_MODEL=deepseek-v4-pro

# ── 流水线阶段控制 (1=跳过, 0=执行) ──
PIPELINE_SKIP_DOWNLOAD=0
PIPELINE_SKIP_BEAUTIFY=0
PIPELINE_SKIP_TRANSLATE=0
PIPELINE_SKIP_BURN=0

# ── 校对 (两轮翻译: 翻译 + 中英对照校对) ──
# 校对开关 (1=开启, 0=关闭)
PROOFREAD=1
# 校对专用后端/模型 (留空则与翻译共用, 可实现交叉校对)
PROOFREAD_PROVIDER=
PROOFREAD_MODEL=

# ── ffmpeg 字幕硬压 ──
# 视频编码器 (hevc_nvenc / libx265 / libx264)
BURN_OVC=hevc_nvenc
# 编码器参数 (qp=20 / crf=23 等)
BURN_OVCOPTS=qp=20
# 音频编码器
BURN_OAC=aac
# 输出分辨率 (如 1920x1080, 保持宽高比加黑边; 留空=原始分辨率)
BURN_RES=

# ── API keys (至少配置一个对应 TRANSLATE_PROVIDER 的 key) ──
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx
# https://aistudio.google.com
GEMINI_API_KEY=xxx
