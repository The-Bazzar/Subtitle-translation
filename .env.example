# ── 工具路径 (留空则用系统默认, Windows/Linux 分开) ──
MPV_PATH_WIN=
MPV_PATH_LINUX=
FFMPEG_PATH_WIN=
FFMPEG_PATH_LINUX=
YTDLP_PATH_WIN=
YTDLP_PATH_LINUX=
PYTHON_PATH_WIN=
PYTHON_PATH_LINUX=
WHISPERX_PATH_WIN=
WHISPERX_PATH_LINUX=

# ── WhisperX 语音识别 ──
# ASR 模型 (large-v3-turbo / large-v3 / small)
WHISPER_MODEL=large-v3-turbo
# 对齐模型 (Facebook MMS 或按语言自动)
WHISPER_ALIGN_MODEL=facebook/mms-1b-fl102
# 推理设备 (cuda / cpu; 留空则跟随 TORCH_BACKEND 自动推导)
WHISPER_DEVICE=
# Hugging Face token，可提高 WhisperX/对齐模型下载速率限制；可留空
HF_TOKEN=
# PyTorch 安装后端: auto / cuda128 / cpu
TORCH_BACKEND=auto

# ── 翻译默认配置 ──
# 源/目标语言可写 ISO 代码或语言名；输出文件后缀会规范为 ISO 639 代码
SOURCE_LANG=
TARGET_LANG=zh
# openai | llama | openrouter | deepseek | gemini
TRANSLATE_PROVIDER=deepseek
# 模型名, 留空则使用后端内置默认
TRANSLATE_MODEL=deepseek-v4-pro

# ── Embedding / Chroma 本地向量库 (默认关闭) ──
# 1=启用项目级 Chroma embedding 索引，并在 glossary/translate/proofread 阶段检索注入上下文
EMBEDDING_ENABLED=0
# OpenAI SDK 兼容 provider；默认 openai，可在 providers.json 中自定义
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# 当前仅支持 chroma
EMBEDDING_STORE=chroma
# 留空则使用项目目录下 chroma_db
EMBEDDING_CHROMA_DIR=
EMBEDDING_TOP_K=6
EMBEDDING_CHUNK_CHARS=800
EMBEDDING_BATCH_SIZE=64

# ── 流水线阶段控制 (1=跳过, 0=执行) ──
PIPELINE_SKIP_DOWNLOAD=0
PIPELINE_SKIP_WHISPER=0
PIPELINE_SKIP_BEAUTIFY=0
PIPELINE_SKIP_KNOWLEDGE=0
PIPELINE_SKIP_TRANSLATE=0
PIPELINE_SKIP_BURN=1

# ── 校对 (两轮翻译: 翻译 + 双语对照校对) ──
# 校对开关 (1=开启, 0=关闭)
PROOFREAD=1
# 校对专用后端/模型 (留空则与翻译共用, 可实现交叉校对)
PROOFREAD_PROVIDER=
PROOFREAD_MODEL=
# 校对批量；留空则使用 --batch-size 的一半。长视频/大知识库建议 2-10
PROOFREAD_BATCH_SIZE=
# 校对阶段 RAG 每条字幕检索片段数；建议保持较小，避免上下文超长
PROOFREAD_RETRIEVAL_TOP_K=1

# ── ffmpeg 字幕硬压 ──
# 视频编码器 (hevc_nvenc / libx265 / libx264)
BURN_OVC=hevc_nvenc
# 编码器参数 (source-bitrate 自动接近源视频码率；也可填 qp=20 / crf=23 等)
BURN_OVCOPTS=source-bitrate
# 音频编码器；mpv 不支持 copy 作为 encode codec，默认使用 aac
BURN_OAC=aac
# 输出分辨率 (如 1920x1080, 保持宽高比加黑边; 留空=原始分辨率)
BURN_RES=

# ── API keys (至少配置一个对应 TRANSLATE_PROVIDER 的 key) ──
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx
# Ollama OpenAI-compatible local server placeholder key
OLLAMA_API_KEY=ollama
# https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx
# https://aistudio.google.com
GEMINI_API_KEY=xxx
# https://tavily.com (联网搜索, glossary 自动生成用)
TAVILY_API_KEY=tvly-xxx
# 最终注入 glossary 的联网搜索结果总数上限 (默认: 20)
TAVILY_MAX_RESULTS=20
# Tavily 搜索 query 总数上限；标题/作者等原视频元信息会优先占用名额
TAVILY_MAX_QUERIES=15
